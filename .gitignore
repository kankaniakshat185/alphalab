# =============================================================================
# AlphaLab — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# PRIVATE — never push to GitHub
# -----------------------------------------------------------------------------
internal/
.env

# -----------------------------------------------------------------------------
# Internal project management — not relevant for public GitHub
# -----------------------------------------------------------------------------
CONTRIBUTING.md
TASKS.md
SKELETON_GUIDE.md
CHANGELOG.md
SECURITY.md
.github/CODEOWNERS
.github/PULL_REQUEST_TEMPLATE.md
.github/ISSUE_TEMPLATE/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/
wheels/
*.whl

# Virtual environments
.venv/
venv/
env/
ENV/
.virtualenv/

# Type checker
.mypy_cache/
.dmypy.json
dmypy.json

# Linter
.ruff_cache/

# Testing
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.cover
*.pytest_cache/
nosetests.xml

# Jupyter
.ipynb_checkpoints/
*.ipynb

# pyenv / mise
# .python-version is intentionally COMMITTED (pins the version)
# Only ignore if you prefer not to commit it:
# .python-version

# -----------------------------------------------------------------------------
# Node.js / Next.js (web/)
# -----------------------------------------------------------------------------
node_modules/
.next/
.nuxt/
.cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Infrastructure
# -----------------------------------------------------------------------------
# .env is gitignored — .env.example files are committed as templates
.env
infra/.env

# Docker volumes (if mounted locally)
postgres-data/
redis-data/

# -----------------------------------------------------------------------------
# Editor / IDE
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# Operating System
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.orig
*.log

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
secrets/

# -----------------------------------------------------------------------------
# Local-only documentation
# -----------------------------------------------------------------------------
AlphaLab Development Roadmap.pdf
AlphaLab_Project_Context.md.pdf
AlphaLab_v1_Spec.pdf
SKELETON_GUIDE.md

# Archives
*.zip
*.tar.gz
