# =============================================================================
# AlphaLab — Environment Variables Template
# =============================================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in every value below
# 3. Never commit .env — it is gitignored
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=alphalab
POSTGRES_PASSWORD=<choose-a-strong-password>
POSTGRES_DB=alphalab
POSTGRES_PORT=5432

# SQLAlchemy async connection URL
DATABASE_URL=postgresql+asyncpg://alphalab:<your-password>@localhost:5432/alphalab

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=<choose-a-strong-password>
REDIS_PORT=6379

REDIS_URL=redis://:<your-redis-password>@localhost:6379/0
CELERY_BROKER_URL=redis://:<your-redis-password>@localhost:6379/0
CELERY_RESULT_BACKEND=redis://:<your-redis-password>@localhost:6379/1

# -----------------------------------------------------------------------------
# pgAdmin  (optional — only needed with: docker compose --profile tools up -d)
# -----------------------------------------------------------------------------
PGADMIN_EMAIL=admin@alphalab.local
PGADMIN_PASSWORD=<choose-a-strong-password>
PGADMIN_PORT=5050

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO

# Path to the DuckDB analytics database (relative to project root)
DUCKDB_PATH=./data/alphalab.duckdb

# JWT secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=<generate-a-random-64-char-hex-string>
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
